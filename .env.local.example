# ─────────────────────────────────────────────────────────────
# Edify — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Forms & Notifications ─────────────────────────────────────
# Get your key at https://web3forms.com
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# WhatsApp number (digits only, with country code, no + sign)
NEXT_PUBLIC_WHATSAPP_NUMBER=917061285806

# Contact email shown on site
NEXT_PUBLIC_CONTACT_EMAIL=hello@edifyedu.in

# ── Google Sheets (Lead Capture) ──────────────────────────────
# Deploy the Google Apps Script from scripts/google-apps-script-leads.js
# then paste the Web App URL here
NEXT_PUBLIC_LEADS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Legacy lead URL (kept for backward compatibility)
NEXT_PUBLIC_GOOGLE_SHEET_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── Admin Authentication ──────────────────────────────────────
# Password to log into /admin (keep this secret!)
ADMIN_SECRET=change-me-to-a-strong-password

# Session token (generate with: openssl rand -hex 32)
ADMIN_SESSION_TOKEN=generate-a-random-64-char-hex-string

# ── CMS (Google Sheets sync) ─────────────────────────────────
ADMIN_API_SECRET=same-as-admin-secret
NEXT_PUBLIC_CMS_SHEET_URL=https://script.google.com/macros/s/YOUR_CMS_SCRIPT_ID/exec
CMS_SHEET_SECRET=same-as-admin-secret

# ── GitHub (automated blog publishing) ───────────────────────
# Create a Personal Access Token at github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_BRANCH=main

# ── Analytics & Cache ─────────────────────────────────────────
# Your GA4 Measurement ID (from Google Analytics)
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ISR revalidation secret (generate with: openssl rand -hex 32)
REVALIDATE_SECRET=generate-a-random-64-char-hex-string
