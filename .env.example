# ============================================
# EdifyEdu.in — Environment Variables
# ============================================
# Rename this file to: .env.local
# Fill in your values below
# NEVER upload this file to GitHub
# ============================================

NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-key-here
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX
NEXT_PUBLIC_CONTACT_EMAIL=hello@edifyedu.in
NEXT_PUBLIC_GOOGLE_SHEET_URL=your-google-apps-script-url-here

# API route protection — set this in Vercel env vars
# Admin pages send this in X-Admin-Token header for API calls
ADMIN_API_SECRET=your-random-secret-here

# Optional: override admin password via env (recommended over hardcoding)
NEXT_PUBLIC_ADMIN_PASSWORD=your-admin-password

# ── Admin auth (REQUIRED for admin panel) ────────────────────────────────
# ADMIN_SECRET: the password users type on the login screen
# ADMIN_SESSION_TOKEN: a random string (run: openssl rand -hex 32)
# Both must be set in Vercel Dashboard → Settings → Environment Variables
ADMIN_SECRET=your-admin-password-here
ADMIN_SESSION_TOKEN=replace-with-output-of-openssl-rand-hex-32

# ── Google Analytics 4 ──────────────────────────────────────────────────
# Get your Measurement ID from analytics.google.com → Admin → Data Streams
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ── Google Search Console ────────────────────────────────────────────────
# After verifying your domain in Search Console, submit sitemap:
# https://edifyedu.in/sitemap.xml

# ── Google Sheets CMS ────────────────────────────────────────────────────
# The Web App URL from your deployed Google Apps Script (scripts/google-apps-script.js)
# Setup: Extensions → Apps Script → Deploy → New Deployment → Web App → Anyone
NEXT_PUBLIC_CMS_SHEET_URL=your-gas-web-app-url-here

# Optional: secret for CMS write operations (must match what you set via setSecret() in GAS)
CMS_SHEET_SECRET=your-cms-secret-here

# ── GitHub deploy (required for CMS sync) ───────────────────────────────
# Personal Access Token with repo write scope
# github.com → Settings → Developer settings → Personal access tokens → Tokens (classic)
GITHUB_TOKEN=ghp_your-token-here
GITHUB_OWNER=careedify-sys
GITHUB_REPO=edify-edu
GITHUB_BRANCH=main

# ── ISR Revalidation (required for on-demand cache updates) ─────────────
# Secret for triggering on-demand ISR from Google Apps Script
# Generate with: openssl rand -hex 32
# Also set this in GAS ScriptProperties as REVALIDATE_SECRET
REVALIDATE_SECRET=your-revalidate-secret-here
